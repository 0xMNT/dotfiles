# kanshi monitor profile configuration
# Handles hot-plugging: automatically applies the right layout when
# monitors are connected/disconnected.
#
# To get your monitor's description for matching, run:
#   wlr-randr   or   hyprctl monitors
# Then replace "HDMI-A-1" with the exact description string if needed.
#
# Apply manually: kanshictl reload
# Start as a service: exec-once = kanshi  (already in laptop.conf)

# Laptop docked: external monitor above, laptop below
profile docked {
    output HDMI-A-1 enable mode 3840x2160@60Hz position 0,0 scale 2
    output eDP-1    enable mode 1920x1080@60Hz position 192,1080 scale 1.25
    exec pkill waybar; waybar &
    exec ~/.config/hypr/restore-wallpaper.sh
}

# Laptop only: no external monitor connected
profile laptop-only {
    output eDP-1    enable mode 1920x1080@60Hz position 0,0 scale 1.25
    output HDMI-A-1 disable
    exec pkill waybar; waybar &
}
